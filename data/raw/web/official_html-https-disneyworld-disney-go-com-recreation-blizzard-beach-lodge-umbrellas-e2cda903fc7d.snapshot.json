    {
      "line": 11,
      "text": "Discover a Very Cool Upgrade"
    },
    {
      "line": 12,
      "text": "When you rent a lodge umbrella for the day, you’ll have access to:"
    },
    {
      "line": 13,
      "text": "1 beach umbrella"
    },
    {
      "line": 14,
      "text": "2 lounge chairs"
