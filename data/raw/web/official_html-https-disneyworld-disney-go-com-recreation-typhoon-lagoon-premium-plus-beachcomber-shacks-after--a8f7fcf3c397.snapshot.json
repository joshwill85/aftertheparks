      "line": 62,
      "text": "Know Before You Go"
    },
    {
      "line": 63,
      "text": "Reservations"
    },
    {
      "line": 64,
      "text": "Advance reservations are highly recommended as Beachcomber Shacks book quickly—and are available on a first-come, first-served basis."
    },
    {
      "line": 65,
      "text": "To inquire about same-day availability during Disney H2O Glow After Hours at Disney’s Typhoon Lagoon, please visit Singapore Sal's after 6:00 PM."
    },
    {
      "line": 66,
      "text": "Prices"
    },
    {
      "line": 67,
      "text": "Beachcomber Shacks Premium Plus cost $225 plus tax during Disney H2O Glow After Hours at Disney’s Typhoon Lagoon."
    },
    {
      "line": 68,
      "text": "Admission Required"
    },
    {
      "line": 69,
      "text": "Valid Disney H2O Glow After Hours at Disney’s Typhoon Lagoon admission is required."
    },
    {
      "line": 70,
      "text": "Age Requirements"
    },
    {
      "line": 71,
      "text": "One Guest in the party must be at least 18 years old."
    },
    {
      "line": 72,
      "text": "Cancellations and No-Shows"
    },
    {
      "line": 73,
      "text": "Guests who need to cancel Beachcomber Shack reservations must provide 24-hour advance notice. The full price of your reservation will be charged in the event of no-shows or same-day cancellations."
    },
    {
      "line": 74,
      "text": "Inclement Weather"
    },
    {
      "line": 75,
      "text": "Rentals may be cancelled by the water park due to inclement weather. If this occurs, Guests will not be charged."
    },
    {
      "line": 76,
      "text": "Subject to Change"
    },
    {
      "line": 77,
      "text": "Availability of amenities may change without notice. Please check at the time of booking to confirm what will be provided."
    },
