    {
      "line": 62,
      "text": "Know Before You Go"
    },
    {
      "line": 63,
      "text": "Reservations"
    },
    {
      "line": 64,
      "text": "Advance reservations are highly recommended as Beachcomber Shacks book quickly—and are available on a first-come, first-served basis."
    },
    {
      "line": 65,
      "text": "To inquire about same-day availability, please visit the podiums at the main entrance near Disney transportation drop off before 11:00 AM. All guests can check in at Singapore Sal’s after 11:00 AM."
    },
    {
      "line": 66,
      "text": "Pricing"
    },
    {
      "line": 67,
      "text": "Prices for Beachcomber Shacks Premium Plus vary based on date—and range from $375 to $550 per day, plus tax."
    },
    {
      "line": 68,
      "text": "Admission Required"
    },
    {
      "line": 69,
      "text": "Valid water park admission is required."
    },
    {
      "line": 70,
      "text": "Age Requirements"
    },
    {
      "line": 71,
      "text": "One Guest in the party must be at least 18 years old."
    },
    {
      "line": 72,
      "text": "Cancellations and No-Shows"
    },
    {
      "line": 73,
      "text": "Guests who need to cancel Beachcomber Shack reservations must provide 24-hour advance notice. The full price of your reservation will be charged in the event of no-shows or same-day cancellations."
    },
    {
      "line": 74,
      "text": "Inclement Weather"
    },
    {
      "line": 75,
      "text": "Rentals may be cancelled by the water park due to inclement weather. If this occurs, Guests will not be charged."
    },
    {
      "line": 76,
      "text": "Hours of Operation"
    },
    {
      "line": 77,
      "text": "Rental spaces are available from park open until 5:00 PM. Extensions into the evening may be available on select nights."
    },
    {
      "line": 78,
      "text": "Subject to Change"
    },
    {
      "line": 79,
      "text": "Operating hours and the availability of amenities may change without notice. Please check at the time of booking to confirm what will be provided."
    },
    {
      "line": 80,
      "text": "Related Activities"
    },
    {
      "line": 81,
      "text": "Beachcomber Shacks Standard"
    },
    {
      "line": 82,
      "text": "Relax in your own private shaded area with cushioned seating, a cooler and more at Disney’s Typhoon Lagoon water park."
