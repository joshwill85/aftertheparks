NEXT_PUBLIC_SUPABASE_URL=https://ujmihdveyqmwehuaqpay.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
NEXT_PUBLIC_EASTER_EGGS=true
NEXT_PUBLIC_SITE_URL=https://aftertheparks.com
TMDB_API_KEY=your-tmdb-api-key
TMDB_READ_ACCESS_TOKEN=your-tmdb-read-access-token

# Search engine ownership verification (optional until dashboard tokens exist)
# Prefer the non-public names; public aliases are supported for hosts that only
# expose public env vars to metadata builds.
GOOGLE_SITE_VERIFICATION=
BING_SITE_VERIFICATION=
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_BING_SITE_VERIFICATION=

# Google Search Console API submission (optional)
# Leave GOOGLE_SEARCH_CONSOLE_SITE_URL empty to use sc-domain:aftertheparks.com.
# Set it to https://aftertheparks.com/ only if the verified Search Console
# property is URL-prefix rather than domain.
GOOGLE_SEARCH_CONSOLE_ACCESS_TOKEN=
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_SEARCH_CONSOLE_CLIENT_EMAIL=
GOOGLE_SEARCH_CONSOLE_PRIVATE_KEY=
GOOGLE_SEARCH_CONSOLE_SITE_URL=

# Bing Webmaster Tools API submission (optional)
# Leave BING_WEBMASTER_SITE_URL empty to use NEXT_PUBLIC_SITE_URL.
# Set it only if Bing's verified site URL needs an exact trailing-slash form.
BING_WEBMASTER_API_KEY=
BING_WEBMASTER_SITE_URL=

# Cloudflare AI Crawl Control / WAF evidence
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_ACCOUNT_ID=

# Cloudflare Turnstile (My Plan bot protection)
# Run: npm run bootstrap:turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key
TURNSTILE_SECRET_KEY=your-turnstile-secret-key

# Optional plan quotas (defaults shown)
# PLAN_MAX_ACTIVE_ITEMS=100
# PLAN_MAX_LIFETIME_ITEMS=250
# PLAN_MAX_SHARE_ROTATIONS_PER_DAY=3
# PLAN_MAX_COPY_PER_ACTION=50
# PLAN_MAX_TITLE_LENGTH=80
# PLAN_MAX_SNAPSHOT_BYTES=8192

# Cron secret for /api/cron/plan-cleanup
CRON_SECRET=your-cron-secret

# Weather guidance layer
# WeatherAPI.com Free: optional friendly current / 0-3 day forecast layer
WEATHERAPI_KEY=
WEATHERAPI_PLAN=free
WEATHERAPI_FORECAST_DAYS=3
WEATHERAPI_ENABLED=true
WEATHERAPI_MONTHLY_FREE_CALL_LIMIT=100000
WEATHER_NOWCAST_ENABLED=true
WEATHER_PRECIP_MAPS_ENABLED=true
WEATHER_WARM_CACHE_ENABLED=true

# National Weather Service: official alerts + free 0-7 day forecast
NWS_USER_AGENT="AfterTheParks.com, contact@aftertheparks.com"
NWS_ALERTS_ENABLED=true
NWS_FORECAST_ENABLED=true
NWS_FORECAST_HOURS=168

# Visual Crossing Free: optional 8-15 day planning outlook
VISUAL_CROSSING_KEY=
VISUAL_CROSSING_ENABLED=false
VISUAL_CROSSING_FORECAST_DAYS=15
VISUAL_CROSSING_FREE_RECORDS_PER_DAY=1000
VISUAL_CROSSING_ATTRIBUTION_ENABLED=true

# Safety and cost guardrails
PAID_WEATHER_PROVIDERS_ALLOWED=false
WEATHER_LONG_RANGE_MAX_DAYS=15
WEATHER_SHOW_PAST_EVENTS=false
ROUTE_WEATHER_ENABLED=false
NEXT_PUBLIC_ROUTE_WEATHER_ENABLED=false
